<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net462;net48;net8.0-windows;net10.0-windows</TargetFrameworks>
    <LangVersion>7.3</LangVersion>
    <Nullable>disable</Nullable>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>disable</ImplicitUsings>

    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>TitlebarAdaptive.WPF</PackageId>
    <Version>1.0.0</Version>
    <Authors>JamesBaiJun</Authors>
    <Company>JamesBaiJun</Company>
    <Description>WPF title bar adaptive helper.</Description>
    <PackageTags>wpf;theme;titlebar</PackageTags>
    <RepositoryUrl>https://github.com/JamesBaiJun/TitlebarAdaptive.WPF</RepositoryUrl>
  </PropertyGroup>

</Project>
