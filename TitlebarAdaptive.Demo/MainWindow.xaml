<Window x:Class="TitlebarAdaptive.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TitlebarAdaptive.Demo"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tool="clr-namespace:TitlebarAdaptive.WPF;assembly=TitlebarAdaptive.WPF"
        Title="MainWindow"
        Width="800"
        Height="450"
        tool:OriginalWindowHelper.Adaptive="False"
        tool:OriginalWindowHelper.TitleBarIsLight="True"
        mc:Ignorable="d">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <CheckBox Margin="8"
                      Content="Adaptive Titlebar"
                      FontSize="14"
                      IsChecked="{Binding Path=(tool:OriginalWindowHelper.Adaptive), RelativeSource={RelativeSource AncestorType=Window}}" />

            <CheckBox Margin="8"
                      Content="Light Titlebar"
                      FontSize="14"
                      IsChecked="{Binding Path=(tool:OriginalWindowHelper.TitleBarIsLight), RelativeSource={RelativeSource AncestorType=Window}}" />
        </StackPanel>
    </Grid>
</Window>
